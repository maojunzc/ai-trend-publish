<%
function renderContentBlock(html) {
  return (html || "")
    .replace(/<img\b([^>]*)\/?>/gi, function(_, attrs) {
      attrs = attrs.replace(/\sstyle=(["']).*?\1/gi, "").replace(/\/\s*$/, "");
      return '<img' + attrs + ' style="max-width:100%;display:block;margin:18px auto;border-radius:6px;border:1px solid #e5e7eb;" />';
    })
    .replace(/<strong>/gi, '<strong style="font-weight:700;color:#111827;">')
    .replace(/<em>/gi, '<em style="font-style:normal;color:#4b5563;">')
    .replace(/<ul>/gi, '<section style="margin:14px 0;padding:0;">')
    .replace(/<\/ul>/gi, '</section>')
    .replace(/<ol>/gi, '<section style="margin:14px 0;padding:0;">')
    .replace(/<\/ol>/gi, '</section>')
    .replace(/<li>/gi, '<p style="margin:8px 0;padding:8px 10px;background:#f9fafb;border-left:3px solid #111827;font-size:15px;line-height:1.75;color:#374151;">')
    .replace(/<\/li>/gi, '</p>');
}
%>
<section style="margin:0 auto;max-width:100%;padding:22px 16px;font-family:-apple-system,BlinkMacSystemFont,'PingFang SC','Microsoft YaHei',sans-serif;color:#1f2937;background:#ffffff;line-height:1.82;">
  <section style="margin:0 0 30px;padding:18px 0;border-top:3px solid #111827;border-bottom:1px solid #e5e7eb;">
    <p style="margin:0 0 8px;color:#6b7280;font-size:12px;font-weight:700;letter-spacing:0.12em;line-height:1.2;">CHANGELOG</p>
    <p style="margin:0;color:#111827;font-size:24px;font-weight:800;line-height:1.35;">产品更新摘要</p>
    <p style="margin:10px 0 0;color:#6b7280;font-size:13px;line-height:1.75;">适合版本更新、功能发布、产品观察和运营公告。</p>
  </section>

  <section style="margin:0 0 30px;padding:14px;background:#f9fafb;border:1px solid #e5e7eb;">
    <p style="margin:0 0 10px;color:#111827;font-size:14px;font-weight:800;line-height:1.4;">本期更新</p>
    <% for(var i=0; i<articles.length; i++) { var article=articles[i]; %>
      <p style="margin:8px 0;color:#374151;font-size:14px;font-weight:600;line-height:1.7;">
        <span style="display:inline-block;margin-right:8px;color:#6b7280;">#<%= (i + 1).toString().padStart(2, '0') %></span><%= article.title %>
      </p>
    <% } %>
  </section>

  <% for(var j=0; j<articles.length; j++) { var article=articles[j]; %>
    <section style="margin:34px 0;padding:0 0 22px;border-bottom:1px solid #e5e7eb;">
      <p style="margin:0 0 8px;color:#6b7280;font-size:12px;font-weight:700;letter-spacing:0.10em;">RELEASE <%= (j + 1).toString().padStart(2, '0') %></p>
      <h3 style="margin:0 0 8px;color:#111827;font-size:21px;font-weight:800;line-height:1.45;"><%= article.title %></h3>
      <p style="margin:0 0 16px;color:#9ca3af;font-size:13px;line-height:1.4;"><%= article.publishDate %></p>
      <section style="margin:0 0 18px;padding:12px;background:#f9fafb;border-left:3px solid #111827;">
        <p style="margin:0;color:#4b5563;font-size:14px;line-height:1.75;">以下内容为本条更新的核心信息与背景摘要。</p>
      </section>
      <% var content=article.content || ""; var paragraphs=content.split("<next_paragraph />");
      for(var i=0; i<paragraphs.length; i++) { var para=paragraphs[i].trim(); if(para.length>0) { %>
        <section style="margin:0 0 18px;color:#374151;font-size:15px;line-height:1.88;text-align:left;letter-spacing:0.02em;">
          <%- renderContentBlock(para) %>
        </section>
      <% }} %>
    </section>
  <% } %>
</section>
