<%
function renderContentBlock(html) {
  return (html || "")
    .replace(/<img\b([^>]*)\/?>/gi, function(_, attrs) {
      attrs = attrs.replace(/\sstyle=(["']).*?\1/gi, "").replace(/\/\s*$/, "");
      return '<img' + attrs + ' style="max-width:100%;display:block;margin:22px auto;border-radius:4px;" />';
    })
    .replace(/<strong>/gi, '<strong style="font-weight:700;color:#111111;">')
    .replace(/<em>/gi, '<em style="font-style:normal;color:#666666;">')
    .replace(/<ul>/gi, '<section style="margin:16px 0;padding:0;">')
    .replace(/<\/ul>/gi, '</section>')
    .replace(/<ol>/gi, '<section style="margin:16px 0;padding:0;">')
    .replace(/<\/ol>/gi, '</section>')
    .replace(/<li>/gi, '<p style="margin:8px 0;padding-left:12px;border-left:2px solid #111111;font-size:15px;line-height:1.85;color:#333333;">')
    .replace(/<\/li>/gi, '</p>');
}
%>
<section style="margin:0 auto;max-width:100%;padding:22px 18px;font-family:-apple-system,BlinkMacSystemFont,'PingFang SC','Microsoft YaHei',sans-serif;color:#222222;background:#ffffff;line-height:1.9;">
  <section style="margin:0 0 34px;padding-bottom:18px;border-bottom:1px solid #eeeeee;">
    <p style="margin:0 0 8px;color:#999999;font-size:12px;font-weight:700;letter-spacing:0.12em;line-height:1.2;">MINIMAL READING</p>
    <p style="margin:0;color:#111111;font-size:24px;font-weight:800;line-height:1.35;">本期文章</p>
  </section>

  <section style="margin:0 0 34px;">
    <% for(var i=0; i<articles.length; i++) { var article=articles[i]; %>
      <p style="margin:0 0 12px;padding-bottom:12px;border-bottom:1px solid #f2f2f2;color:#222222;font-size:14px;font-weight:700;line-height:1.7;">
        <span style="display:inline-block;margin-right:10px;color:#999999;"><%= (i + 1).toString().padStart(2, '0') %></span><%= article.title %>
      </p>
    <% } %>
  </section>

  <% for(var j=0; j<articles.length; j++) { var article=articles[j]; %>
    <section style="margin:42px 0;">
      <p style="margin:0 0 10px;color:#999999;font-size:12px;font-weight:700;letter-spacing:0.10em;">ARTICLE <%= (j + 1).toString().padStart(2, '0') %></p>
      <h3 style="margin:0 0 10px;color:#111111;font-size:22px;font-weight:800;line-height:1.45;"><%= article.title %></h3>
      <p style="margin:0 0 20px;color:#999999;font-size:13px;line-height:1.4;"><%= article.publishDate %></p>
      <% var content=article.content || ""; var paragraphs=content.split("<next_paragraph />");
      for(var i=0; i<paragraphs.length; i++) { var para=paragraphs[i].trim(); if(para.length>0) { %>
        <section style="margin:0 0 20px;color:#333333;font-size:15px;line-height:1.95;text-align:left;letter-spacing:0.02em;">
          <%- renderContentBlock(para) %>
        </section>
      <% }} %>
    </section>
    <% if (j < articles.length - 1) { %>
      <section style="margin:42px 0;height:1px;background:#eeeeee;font-size:0;line-height:0;">&nbsp;</section>
    <% } %>
  <% } %>
</section>
