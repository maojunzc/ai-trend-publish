<%
function renderContentBlock(html) {
  return (html || "")
    .replace(/<img\b([^>]*)\/?>/gi, function(_, attrs) {
      attrs = attrs.replace(/\sstyle=(["']).*?\1/gi, "").replace(/\/\s*$/, "");
      return '<img' + attrs + ' style="max-width:100%;display:block;margin:20px auto;border-radius:4px;border:1px solid #2a2f36;" />';
    })
    .replace(/<strong>/gi, '<strong style="font-weight:700;color:#f5f5f5;">')
    .replace(/<em>/gi, '<em style="font-style:normal;color:#aeb6c2;">')
    .replace(/<ul>/gi, '<section style="margin:16px 0;padding:0;">')
    .replace(/<\/ul>/gi, '</section>')
    .replace(/<ol>/gi, '<section style="margin:16px 0;padding:0;">')
    .replace(/<\/ol>/gi, '</section>')
    .replace(/<li>/gi, '<p style="margin:8px 0;padding:9px 12px;background:#171a1f;border-left:2px solid #d6d6d6;font-size:15px;line-height:1.8;color:#d8dde5;">')
    .replace(/<\/li>/gi, '</p>');
}
%>
<section style="margin:0 auto;max-width:100%;padding:22px 16px;font-family:-apple-system,BlinkMacSystemFont,'PingFang SC','Microsoft YaHei',sans-serif;color:#d8dde5;background:#111418;line-height:1.88;">
  <section style="margin:0 0 34px;padding:0 0 20px;border-bottom:1px solid #2a2f36;">
    <p style="margin:0 0 10px;color:#8d96a3;font-size:12px;font-weight:700;letter-spacing:0.14em;line-height:1.2;">RESEARCH NOTE</p>
    <p style="margin:0;color:#f5f5f5;font-size:24px;font-weight:800;line-height:1.35;">研究笔记</p>
    <p style="margin:10px 0 0;color:#8d96a3;font-size:13px;line-height:1.75;">深色版式用于强调信息密度，不做高饱和科技装饰。</p>
  </section>

  <section style="margin:0 0 34px;">
    <% for(var i=0; i<articles.length; i++) { var article=articles[i]; %>
      <section style="margin:0 0 14px;padding:0 0 14px;border-bottom:1px solid #242a31;">
        <p style="margin:0;color:#d8dde5;font-size:14px;font-weight:700;line-height:1.7;">
          <span style="display:inline-block;margin-right:9px;color:#8d96a3;"><%= (i + 1).toString().padStart(2, '0') %></span><%= article.title %>
        </p>
      </section>
    <% } %>
  </section>

  <% for(var j=0; j<articles.length; j++) { var article=articles[j]; %>
    <section style="margin:40px 0;">
      <p style="margin:0 0 8px;color:#8d96a3;font-size:12px;font-weight:700;letter-spacing:0.12em;">NOTE <%= (j + 1).toString().padStart(2, '0') %></p>
      <h3 style="margin:0 0 8px;color:#f5f5f5;font-size:21px;font-weight:800;line-height:1.45;"><%= article.title %></h3>
      <p style="margin:0 0 20px;color:#8d96a3;font-size:13px;line-height:1.4;"><%= article.publishDate %></p>
      <% var content=article.content || ""; var paragraphs=content.split("<next_paragraph />");
      for(var i=0; i<paragraphs.length; i++) { var para=paragraphs[i].trim(); if(para.length>0) { %>
        <section style="margin:0 0 19px;color:#d8dde5;font-size:15px;line-height:1.92;text-align:left;letter-spacing:0.02em;">
          <%- renderContentBlock(para) %>
        </section>
      <% }} %>
    </section>
    <% if (j < articles.length - 1) { %>
      <section style="margin:40px 0;height:1px;background:#2a2f36;font-size:0;line-height:0;">&nbsp;</section>
    <% } %>
  <% } %>
</section>
