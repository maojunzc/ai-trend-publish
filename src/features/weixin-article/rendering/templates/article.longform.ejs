<%
function renderContentBlock(html) {
  return (html || "")
    .replace(/<img\b([^>]*)\/?>/gi, function(_, attrs) {
      attrs = attrs.replace(/\sstyle=(["']).*?\1/gi, "").replace(/\/\s*$/, "");
      return '<img' + attrs + ' style="max-width:100%;display:block;margin:24px auto 22px;border-radius:4px;" />';
    })
    .replace(/<strong>/gi, '<strong style="font-weight:700;color:#202020;">')
    .replace(/<em>/gi, '<em style="font-style:normal;color:#6f6253;">')
    .replace(/<ul>/gi, '<section style="margin:18px 0;padding:0;">')
    .replace(/<\/ul>/gi, '</section>')
    .replace(/<ol>/gi, '<section style="margin:18px 0;padding:0;">')
    .replace(/<\/ol>/gi, '</section>')
    .replace(/<li>/gi, '<p style="margin:9px 0;padding-left:14px;border-left:2px solid #b7a58b;font-size:15px;line-height:1.9;color:#333333;">')
    .replace(/<\/li>/gi, '</p>');
}
%>
<section style="margin:0 auto;max-width:100%;padding:24px 18px;font-family:-apple-system,BlinkMacSystemFont,'PingFang SC','Microsoft YaHei',sans-serif;color:#252525;background:#ffffff;line-height:1.92;">
  <section style="margin:0 0 36px;padding:0 0 22px;border-bottom:2px solid #202020;">
    <p style="margin:0 0 12px;color:#888888;font-size:12px;font-weight:700;letter-spacing:0.14em;line-height:1.2;">LONG READ</p>
    <p style="margin:0;color:#111111;font-size:26px;font-weight:800;line-height:1.32;">深度阅读</p>
    <p style="margin:12px 0 0;color:#777777;font-size:13px;line-height:1.8;">为长文和专题保留更多呼吸感，减少装饰，让标题、段落和留白承担层次。</p>
  </section>

  <section style="margin:0 0 40px;">
    <% for(var i=0; i<articles.length; i++) { var article=articles[i]; %>
      <section style="margin:0 0 18px;padding:0 0 18px;border-bottom:1px solid #eeeeee;">
        <p style="margin:0 0 6px;color:#999999;font-size:12px;font-weight:700;letter-spacing:0.08em;">0<%= i + 1 %></p>
        <p style="margin:0;color:#202020;font-size:16px;font-weight:700;line-height:1.65;"><%= article.title %></p>
      </section>
    <% } %>
  </section>

  <% for(var j=0; j<articles.length; j++) { var article=articles[j]; %>
    <section style="margin:46px 0;">
      <p style="margin:0 0 14px;color:#999999;font-size:12px;font-weight:700;letter-spacing:0.12em;">CHAPTER <%= (j + 1).toString().padStart(2, '0') %></p>
      <h3 style="margin:0;color:#111111;font-size:24px;font-weight:800;line-height:1.42;"><%= article.title %></h3>
      <p style="margin:12px 0 24px;color:#999999;font-size:13px;line-height:1.4;"><%= article.publishDate %></p>
      <% var content=article.content || ""; var paragraphs=content.split("<next_paragraph />");
      for(var i=0; i<paragraphs.length; i++) { var para=paragraphs[i].trim(); if(para.length>0) { %>
        <section style="margin:0 0 22px;color:#333333;font-size:15px;line-height:2;text-align:left;letter-spacing:0.02em;">
          <%- renderContentBlock(para) %>
        </section>
      <% }} %>
    </section>
    <% if (j < articles.length - 1) { %>
      <section style="margin:46px 0;height:1px;background:#dddddd;font-size:0;line-height:0;">&nbsp;</section>
    <% } %>
  <% } %>
</section>
