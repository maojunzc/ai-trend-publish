<%
let totalWords = 0;
let totalReadTime = 0;
let hasStats = false;
articles.forEach(function(article) {
  if (article.metadata && typeof article.metadata.wordCount === "number" && typeof article.metadata.readTime === "number") {
    totalWords += article.metadata.wordCount;
    totalReadTime += article.metadata.readTime;
    hasStats = true;
  }
});
function renderContentBlock(html) {
  return (html || "")
    .replace(/<img\b([^>]*)\/?>/gi, function(_, attrs) {
      attrs = attrs.replace(/\sstyle=(["']).*?\1/gi, "").replace(/\/\s*$/, "");
      return '<img' + attrs + ' style="max-width:100%;display:block;margin:20px auto;border-radius:12px;box-shadow:0 8px 22px rgba(22,119,255,0.12);" />';
    })
    .replace(/<strong>/gi, '<strong style="font-weight:700;color:#1677ff;">')
    .replace(/<em>/gi, '<em style="font-style:normal;color:#05a7a0;">')
    .replace(/<ul>/gi, '<section style="margin:16px 0;padding:0;">')
    .replace(/<\/ul>/gi, '</section>')
    .replace(/<ol>/gi, '<section style="margin:16px 0;padding:0;">')
    .replace(/<\/ol>/gi, '</section>')
    .replace(/<li>/gi, '<p style="margin:8px 0;padding:10px 12px;background:linear-gradient(90deg, rgba(22,119,255,0.06), rgba(5,212,205,0.03));border-left:3px solid #1677ff;border-radius:7px;font-size:15px;line-height:1.75;color:#4e5969;">')
    .replace(/<\/li>/gi, '</p>');
}
%>
<section style="
    margin: 0 auto;
    max-width: 100%;
    padding: 18px 16px;
    font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
    line-height: 1.75;
    color: #1d2129;
    background: #ffffff;
  ">
  <section style="margin:0 0 32px;padding:22px 18px;background:linear-gradient(135deg, rgba(22,119,255,0.08), rgba(5,212,205,0.06));border-radius:14px;border-top:4px solid #1677ff;border-bottom:1px solid rgba(5,212,205,0.40);box-shadow:0 8px 20px rgba(22,119,255,0.08);">
    <p style="margin:0 0 8px;color:#1677ff;font-size:12px;font-weight:800;line-height:1.2;letter-spacing:0.08em;">
      TECH SIGNAL
    </p>
    <p style="margin:0 0 16px;color:#1d2129;font-size:22px;font-weight:800;line-height:1.35;">
      AI 趋势速览
    </p>
    <% if (hasStats) { %>
      <section style="margin:0 0 16px;padding:14px;background:#ffffff;border-radius:10px;border:1px solid rgba(22,119,255,0.10);">
        <p style="margin:0 0 8px;color:#1677ff;font-size:14px;font-weight:800;line-height:1.4;">
          阅读指南
        </p>
        <p style="margin:0;color:#4e5969;font-size:13px;line-height:1.8;">
          共 <span style="color:#1677ff;font-weight:700;"><%= totalWords %></span> 字，预计阅读 <span style="color:#1677ff;font-weight:700;"><%= totalReadTime %></span> 分钟
        </p>
      </section>
    <% } %>

    <p style="margin:0 0 14px;padding-bottom:10px;border-bottom:1px solid rgba(22,119,255,0.14);color:#1d2129;font-size:17px;font-weight:800;line-height:1.4;">
      文章目录
    </p>
    <% for(var i=0; i<articles.length; i++) { var article=articles[i]; %>
      <section style="margin:10px 0;padding:12px 14px;background:#ffffff;border-radius:10px;border-left:4px solid #1677ff;box-shadow:0 4px 12px rgba(22,119,255,0.05);">
        <p style="margin:0;color:#1d2129;font-size:14px;font-weight:600;line-height:1.65;">
          <span style="display:inline-block;margin-right:8px;color:#1677ff;font-weight:700;"><%= (i + 1).toString().padStart(2, '0') %></span>
          <%= article.title %>
        </p>
      </section>
    <% } %>
  </section>

  <% for(var j=0; j<articles.length; j++) { var article=articles[j]; %>
    <section style="margin: 40px 0;">
      <p style="margin:0 0 10px;color:#86909c;font-size:12px;font-weight:700;line-height:1.4;letter-spacing:0.08em;">
        <%= (j + 1).toString().padStart(2, '0') %> / <%= articles.length.toString().padStart(2, '0') %>
      </p>
      <section style="
          margin: 0 0 18px;
          padding: 16px 18px;
          background: linear-gradient(90deg, rgba(22,119,255,0.08), rgba(5,212,205,0.03));
          border-left: 4px solid #1677ff;
          border-radius: 12px;
          border-top: 1px solid rgba(22,119,255,0.10);
          border-right: 1px solid rgba(22,119,255,0.10);
          border-bottom: 1px solid rgba(5,212,205,0.10);
        ">
        <h3 style="margin:0;color:#1d2129;font-size:22px;font-weight:800;line-height:1.45;">
          <%= article.title %>
        </h3>
        <p style="margin:8px 0 0;color:#86909c;font-size:13px;line-height:1.4;">
          <%= article.publishDate %>
        </p>
      </section>

      <section style="padding:0 2px 0 4px;">
        <% var content=article.content || ""; var paragraphs=content.split("<next_paragraph />");
        for(var i=0; i<paragraphs.length; i++) { var para=paragraphs[i].trim(); if(para.length>0) { %>
          <section style="margin:0 0 20px;color:#4e5969;font-size:15px;line-height:1.9;text-align:left;letter-spacing:0.02em;">
            <%- renderContentBlock(para) %>
          </section>
        <% }} %>
      </section>
    </section>

    <% if (j < articles.length - 1) { %>
      <section style="margin:40px auto;width:70%;height:2px;background:linear-gradient(90deg, rgba(22,119,255,0), rgba(22,119,255,0.58), rgba(5,212,205,0.58), rgba(5,212,205,0));font-size:0;line-height:0;">&nbsp;</section>
    <% } %>
  <% } %>
</section>
