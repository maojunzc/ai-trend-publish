<%
function renderContentBlock(html) {
  return (html || "")
    .replace(/<img\b([^>]*)\/?>/gi, function(_, attrs) {
      attrs = attrs.replace(/\sstyle=(["']).*?\1/gi, "").replace(/\/\s*$/, "");
      return '<img' + attrs + ' style="max-width:100%;display:block;margin:18px auto;border-radius:10px;box-shadow:0 4px 14px rgba(54,149,246,0.12);" />';
    })
    .replace(/<strong>/gi, '<strong style="font-weight:700;color:#155f9f;background:linear-gradient(180deg, transparent 58%, rgba(54,149,246,0.14) 58%);padding:0 2px;">')
    .replace(/<em>/gi, '<em style="font-style:normal;color:#2f7fbf;">')
    .replace(/<ul>/gi, '<section style="margin:16px 0;padding:0;">')
    .replace(/<\/ul>/gi, '</section>')
    .replace(/<ol>/gi, '<section style="margin:16px 0;padding:0;">')
    .replace(/<\/ol>/gi, '</section>')
    .replace(/<li>/gi, '<p style="margin:8px 0;padding:9px 12px;background:#f7fbff;border-left:3px solid #3695f6;border-radius:6px;font-size:15px;line-height:1.75;color:#38526b;">')
    .replace(/<\/li>/gi, '</p>');
}
%>
<section style="
    margin: 0 auto;
    max-width: 100%;
    padding: 18px 16px;
    font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
    line-height: 1.75;
    color: #38526b;
    background: #ffffff;
  ">
  <section style="margin:0 0 28px;padding:22px 18px;background:linear-gradient(135deg, #eef7ff, #ffffff);border-radius:14px;border:1px solid #dbeeff;text-align:center;box-shadow:0 6px 16px rgba(54,149,246,0.08);">
    <p style="margin:0 0 8px;color:#7a9bc8;font-size:12px;font-weight:700;line-height:1.2;letter-spacing:0.08em;">
      AI DAILY BRIEF
    </p>
    <p style="margin:0;color:#155f9f;font-size:24px;font-weight:800;line-height:1.35;">
      今日 AI 速递
    </p>
    <p style="margin:10px 0 0;color:#6f8fab;font-size:13px;line-height:1.7;">
      精选趋势、产品更新与工程实践
    </p>
  </section>

  <section style="margin: 0 0 32px;padding:16px;background:#fbfdff;border:1px solid #e5f2ff;border-radius:12px;">
    <p style="margin:0 0 14px;padding-bottom:10px;border-bottom:1px solid #dbeeff;color:#155f9f;font-size:17px;font-weight:800;line-height:1.4;">
      本期目录
    </p>

    <% for(var i=0; i<articles.length; i++) { var article=articles[i]; %>
      <section style="margin:10px 0;padding:12px 14px;background:#ffffff;border-left:4px solid #3695f6;border-radius:8px;box-shadow:0 3px 10px rgba(54,149,246,0.05);">
        <p style="margin:0;color:#38526b;font-size:14px;font-weight:700;line-height:1.65;">
          <span style="display:inline-block;margin-right:8px;color:#3695f6;"><%= (i + 1).toString().padStart(2, '0') %></span>
          <%= article.title %>
        </p>
      </section>
    <% } %>
  </section>

  <% for(var j=0; j<articles.length; j++) { var article=articles[j]; %>
    <section style="margin: 38px 0;">
      <section style="margin:0 0 18px;padding:18px;background:linear-gradient(135deg, #f6fbff, #ffffff);border-radius:12px;border-left:5px solid #3695f6;border-top:1px solid #e5f2ff;border-right:1px solid #e5f2ff;border-bottom:1px solid #e5f2ff;">
        <p style="margin:0 0 8px;color:#7a9bc8;font-size:12px;font-weight:700;line-height:1.2;">
          STORY <%= (j + 1).toString().padStart(2, '0') %>
        </p>
        <h3 style="margin:0 0 8px;color:#155f9f;font-size:21px;font-weight:800;line-height:1.45;">
          <%= article.title %>
        </h3>
        <p style="margin:0;color:#7a9bc8;font-size:13px;line-height:1.4;">
          <%= article.publishDate %>
        </p>
      </section>

      <section style="padding:18px 16px;background:#ffffff;border-radius:10px;border:1px solid #e5f2ff;">
        <% var content=article.content || ""; var paragraphs=content.split("<next_paragraph />");
        for(var i=0; i<paragraphs.length; i++) { var para=paragraphs[i].trim(); if(para.length>0) { %>
          <section style="margin:0 0 18px;color:#38526b;font-size:15px;line-height:1.9;text-align:left;letter-spacing:0.02em;">
            <%- renderContentBlock(para) %>
          </section>
        <% }} %>
      </section>
    </section>

    <% if (j < articles.length - 1) { %>
      <section style="margin:34px auto;text-align:center;color:#b8dcff;font-size:20px;line-height:1;">...</section>
    <% } %>
  <% } %>

  <section style="margin:40px 0 0;padding:20px;background:#f6fbff;border-radius:10px;text-align:center;border:1px solid #e5f2ff;">
    <p style="margin:0;font-size:12px;color:#7a9bc8;line-height:1.7;">
      如您有更好的建议，欢迎留言交流
    </p>
  </section>
</section>
